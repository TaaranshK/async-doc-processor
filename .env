# ==============================================================================
# Async Document Processing — Environment Configuration
# ==============================================================================

# Application
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-me-in-production-12345678901234567890
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=docprocessor
POSTGRES_USER=docuser
POSTGRES_PASSWORD=docpassword123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery
CELERY_WORKER_CONCURRENCY=4
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_BASE=2

# File Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/uploads
MAX_FILE_SIZE_BYTES=52428800
CHUNKED_WRITE_THRESHOLD_BYTES=10485760
ALLOWED_MIME_TYPES=application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
VITE_API_URL_INTERNAL=http://api:8000
