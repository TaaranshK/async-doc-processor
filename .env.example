# ==============================================================================
# Async Document Processing — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env to version control.
# ==============================================================================


# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

# Environment: development | staging | production
APP_ENV=development

# Secret key used for JWT signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-random-secret

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# Allowed CORS origins (comma-separated). Use * only in development.
CORS_ORIGINS=http://localhost:3000


# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=docprocessor
POSTGRES_USER=docuser
POSTGRES_PASSWORD=changeme

# Assembled by config.py — do not set manually unless overriding
# DATABASE_URL=postgresql+asyncpg://docuser:changeme@postgres:5432/docprocessor


# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Leave blank if Redis runs without auth (dev only)
REDIS_PASSWORD=

# Assembled by config.py — do not set manually unless overriding
# REDIS_URL=redis://:password@redis:6379/0


# ------------------------------------------------------------------------------
# Celery
# ------------------------------------------------------------------------------

CELERY_WORKER_CONCURRENCY=4
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_BASE=2


# ------------------------------------------------------------------------------
# File Storage
# ------------------------------------------------------------------------------

# Storage backend: local | s3
STORAGE_BACKEND=local

LOCAL_STORAGE_PATH=/app/uploads

# 50 MB
MAX_FILE_SIZE_BYTES=52428800

# 10 MB — files above this use chunked writes
CHUNKED_WRITE_THRESHOLD_BYTES=10485760

ALLOWED_MIME_TYPES=application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document


# ------------------------------------------------------------------------------
# S3 (only required when STORAGE_BACKEND=s3)
# ------------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=


# ------------------------------------------------------------------------------
# Frontend (Next.js)
# ------------------------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://api:8000


# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# json | text
LOG_FORMAT=json