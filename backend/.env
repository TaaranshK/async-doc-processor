# Application Environment
APP_ENV=development

# Secret Key for JWT (generate a strong one in production!)
SECRET_KEY=your-super-secret-key-change-this-in-production-12345678

# JWT Token Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=docprocessor
POSTGRES_USER=docuser
POSTGRES_PASSWORD=Guddiguddi13@

# Redis Cache & Message Broker
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery Background Tasks
CELERY_WORKER_CONCURRENCY=4
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_BASE=2

# File Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/uploads
MAX_FILE_SIZE_BYTES=52428800
CHUNKED_WRITE_THRESHOLD_BYTES=10485760

# Allowed File Types (comma-separated)
ALLOWED_MIME_TYPES=application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Log Format (json or text)
LOG_FORMAT=text
